APP_NAME=price-updater-backend
APP_ENV=dev
DEBUG=true
OUTPUT_ROOT=./runtime_outputs
TMP_ROOT=./runtime_tmp

EXTRACTION_BACKEND=camelot

# Parallel processing (applies to page extraction + row normalization)
PARALLEL_PROCESSING_ENABLED=true
PARALLEL_EXTRACTION_MODE=process
PARALLEL_EXTRACTION_WORKERS=16
PARALLEL_NORMALIZATION_MODE=off
PARALLEL_NORMALIZATION_WORKERS=16
PARALLEL_MIN_PAGES=8

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us
GOOGLE_DOCAI_PROCESSOR_ID=
GOOGLE_DOCAI_PROCESSOR_VERSION=
